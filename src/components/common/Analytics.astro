---
import { ANALYTICS } from '~/config';

const googleAnalyticsId = String(ANALYTICS?.vendors?.googleAnalytics?.id ?? '');
const isValidGoogleAnalyticsId = /^G-[A-Z0-9-]+$/.test(googleAnalyticsId);
const scriptType = ANALYTICS?.vendors?.googleAnalytics?.partytown ? 'text/partytown' : undefined;
---

{
  isValidGoogleAnalyticsId ? (
    <>
      <script
        is:inline
        async
        type={scriptType}
        src={`https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`}
      />
      <script
        is:inline
        type={scriptType}
        set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config',${JSON.stringify(
          googleAnalyticsId
        )});`}
      />
    </>
  ) : null
}
